{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Lab UI Design System Config",
  "type": "object",
  "required": ["primitives"],
  "properties": {
    "primitives": {
      "type": "object",
      "description": "Perceptually-generated color scales",
      "properties": {
        "neutral": {
          "$ref": "#/$defs/scaleConfig"
        }
      },
      "additionalProperties": false
    },
    "accents": {
      "type": "object",
      "description": "Theme-dependent accent colours. Value is either a single hex (all themes) or an object with per-theme overrides.",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "string",
            "pattern": "^#[0-9A-Fa-f]{6}$",
            "description": "Single hex used for all four themes"
          },
          {
            "type": "object",
            "required": ["light", "dark", "ic_light", "ic_dark"],
            "properties": {
              "light": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
              "dark": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
              "ic_light": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
              "ic_dark": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
            }
          }
        ]
      }
    },
    "tint": {
      "type": "object",
      "description": "Precomputed tint matrix settings",
      "properties": {
        "strengths": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0, "maximum": 100 },
          "default": [2, 4, 8, 12, 20, 32, 52, 72],
          "description": "Opacity percentages for precomputed accent-neutral mixes"
        }
      }
    },
    "output": {
      "type": "object",
      "properties": {
        "scss": { "type": "string", "default": "dist/tokens.scss" },
        "json": { "type": "string", "default": "dist/tokens.json" }
      }
    }
  },
  "$defs": {
    "scaleConfig": {
      "type": "object",
      "required": ["light", "base", "dark"],
      "properties": {
        "light": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "base":  { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "dark":  { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "ic": {
          "type": "object",
          "description": "Increased-contrast anchors (inherits parent curve)",
          "required": ["light", "base", "dark"],
          "properties": {
            "light": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
            "base":  { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
            "dark":  { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
          }
        },
        "curve": {
          "type": "object",
          "properties": {
            "lightness_ease": { "type": "number", "default": 1.7 },
            "hue_ease":       { "type": "number", "default": 0.6 },
            "chroma_peak":    { "type": "number", "default": 0.35 }
          }
        }
      }
    }
  }
}
