{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Lab UI Design System Config",
  "type": "object",
  "required": ["primitives"],
  "properties": {
    "primitives": {
      "type": "object",
      "description": "Perceptually-generated color scales",
      "properties": {
        "neutral": {
          "$ref": "#/$defs/scaleConfig"
        },
        "accent": {
          "$ref": "#/$defs/scaleConfig"
        }
      },
      "additionalProperties": false
    },
    "semantic": {
      "type": "object",
      "description": "Named aliases into primitives",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[a-z]+-[0-9]+$"
      }
    },
    "output": {
      "type": "object",
      "properties": {
        "scss": { "type": "string", "default": "dist/tokens.scss" },
        "json": { "type": "string", "default": "dist/tokens.json" }
      }
    }
  },
  "$defs": {
    "scaleConfig": {
      "type": "object",
      "required": ["light", "base", "dark"],
      "properties": {
        "light": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "base":  { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "dark":  { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
      }
    }
  }
}
