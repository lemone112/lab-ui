{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Lab UI Design System Config",
  "type": "object",
  "required": ["primitives"],
  "properties": {
    "primitives": {
      "type": "object",
      "description": "Perceptually-generated color scales",
      "additionalProperties": {
        "$ref": "#/$defs/scaleConfig"
      }
    },
    "accents": {
      "type": "object",
      "description": "Canonical accent hex values. Theme variants are generated algorithmically via APCA.",
      "additionalProperties": {
        "type": "string",
        "pattern": "^#[0-9A-Fa-f]{6}$"
      }
    },
    "accent_theming": {
      "type": "object",
      "description": "Parameters for APCA-based accent theme generation",
      "properties": {
        "dark_factor": {
          "type": "number",
          "default": 0.7,
          "description": "Dark-mode contrast as a fraction of light-mode contrast magnitude"
        },
        "ic_boost": {
          "type": "number",
          "default": 15.0,
          "description": "Increased-contrast boost in APCA Lc"
        }
      }
    },
    "output": {
      "type": "object",
      "properties": {
        "scss": { "type": "string", "default": "dist/tokens.scss" },
        "json": { "type": "string", "default": "dist/tokens.json" }
      }
    }
  },
  "$defs": {
    "scaleConfig": {
      "type": "object",
      "required": ["light", "base", "dark"],
      "properties": {
        "light": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "base":  { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "dark":  { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "ic": {
          "type": "object",
          "description": "Increased-contrast anchors (inherits parent curve)",
          "required": ["light", "base", "dark"],
          "properties": {
            "light": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
            "base":  { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
            "dark":  { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
          }
        },
        "curve": {
          "type": "object",
          "properties": {
            "lightness_ease": { "type": "number", "default": 1.7 },
            "hue_ease":       { "type": "number", "default": 0.6 },
            "chroma_peak":    { "type": "number", "default": 0.35 }
          }
        }
      }
    }
  }
}
